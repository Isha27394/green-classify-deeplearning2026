{
  "version": 2,
  "builds": [
    {
      "src": "api/app.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb",
        "includeFiles": "flask/**"
      }
    },
    {
      "src": "flask/static/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/flask/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/app.py"
    }
  ]
}
